<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.ifinalframework.plugins.aio.mybatis.KotlinMapper">
    <sql id="table">
        t_java
    </sql>
    <sql id="columns">
        `id`, `name`, `age`
    </sql>

    <insert id="insertBatch" useGeneratedKeys="true" keyProperty="list.id">
        INSERT INTO
        <include refid="table"/>
        <trim prefix="(" suffix=")" suffixOverrides=",">
            `name1`,
            `age`,
        </trim>
        VALUES
        <foreach collection="list" item="item" separator=",">
            <trim prefix="(" suffix=")" suffixOverrides=",">
                #{item.name},
                #{item.age, typeHandler=org.ifinalframework.plugins.aio.mybatis.MyTypeHandler},
            </trim>
        </foreach>
    </insert>
    <select id="selectSingle" resultType="org.ifinalframework.plugins.aio.mybatis.ResultMap">
        SELECT
        <include refid="columns"/>
        FROM
        <include refid="table"/>
        <where>
            <if test="null != id">
                AND id = #{id, typeHandler=haha}
            </if>
            <if test="null != name and name != ''">
                AND name = #{name}
            </if>
            <if test="null != age">
                AND age = #{age}
            </if>
            <if test="null != tags and tags.size > 0">
                AND tags IN
                <foreach collection="tags" item="item" open="(" close=")" separator=",">
                    #{item}
                </foreach>
            </if>
            <if test="null != haha">
                AND haha = #{haha}
            </if>
            <if test="null != nullOrNotNull">
                AND null_or_not_null = #{nullOrNotNull}
            </if>
            <if test="null != startDate and null != endDate">
                AND date BETWEEN #{startDate} AND #{endDate}
            </if>
        </where>
    </select>


</mapper>